# ─── sensing-node deployment config ───────────────────────────────────────
# Copy to .env (./scripts/deploy.sh init does this and fills host-specific
# values). The SAME repo runs on the laptop and the server — only this file
# differs per host. .env is gitignored; this .example is committed.

# Topology role for `deploy.sh up`:  all | compute | gui
#   all     = run everything on this one machine            (laptop-only)
#   compute = headless sim + fusion                          (the GPU box / server)
#   gui     = rviz + gazebo-gui only, render locally         (the machine you sit at)
ROLE=all

# ─ ROS 2 / DDS / gz-transport ─────────────────────────────────────────────
ROS_DOMAIN_ID=42
GZ_PARTITION=sensing
# Default DDS is FastDDS (multicast). For multi-host where multicast is blocked:
#   RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
#   CYCLONEDDS_URI=file:///etc/cyclonedds.xml   (edit peers in docker/cyclonedds.xml)
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
CYCLONEDDS_URI=

# ─ GUI (Option 1: render on the LOCAL GPU) ────────────────────────────────
# X display of the machine you sit at. `deploy.sh up gui` runs `xhost +local:`.
DISPLAY=:0
# For a cross-host Gazebo GUI (gz -g on the laptop → gz -s on the server) set
# this to the GUI machine's LAN IP. Leave blank for single-host. See
# docs/headless-gui.md.
GZ_IP=

# ─ Sim world ──────────────────────────────────────────────────────────────
# Empty = Clearpath 'pipeline' world. To drive a prepared WildSeed bundle from
# worlds_external/, use `deploy.sh world <bundle>` — it sets BOTH values
# (SIM_WORLD_NAME must match the <world name> inside the bundle's world.sdf;
# gtbridge's ground-truth gz topic is derived from it).
SIM_WORLD=
SIM_WORLD_NAME=pipeline

# ─ GPU ML (Milestone 7 — opt-in) ──────────────────────────────────────────
WITH_TORCH=0
TORCH_VARIANT=cu121     # floor for driver 535 (laptop); also fine on 595 (server)

# ─ Resource caps (deploy.sh init sets these from this host's nproc / RAM) ──
CPUS=8
MEM_LIMIT=16g
SHM_SIZE=1gb
PIDS_LIMIT=4096

# ─ Data ───────────────────────────────────────────────────────────────────
# Hard-capped, self-pruning datasets dir (PLAN §9.1). Path is relative to
# docker/ (where compose runs) or absolute.
DATASETS_DIR=../datasets

# ─ Remote (scripts/remote.sh — drive the server's headless sim from the laptop) ─
SENSING_SERVER=server.local
SENSING_SERVER_DIR=WildSeedAutonomy
